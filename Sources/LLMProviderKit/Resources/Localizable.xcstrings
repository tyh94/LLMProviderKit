    "llm.openai.preset.ollama.instructions" : {
      "comment" : "Instructions for using the \"OpenAI OLLAMA\" LLM.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Install Ollama from the official website\n2. Start the Ollama server\n3. Download the model using: ollama pull minimax-m3:cloud\n\nAPI key is not required for local usage."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Установите Ollama с официального сайта\n2. Запустите Ollama сервер\n3. Загрузите модель командой: ollama pull minimax-m3:cloud\n\nДля локальной работы API ключ не требуется."
          }
        }
      }
    },
