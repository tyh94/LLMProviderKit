    },
    "llm.openai.preset.llamacpp.instructions" : {
      "comment" : "Instructions for using the LLM with the \"llama.cpp\" preset.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Install llama.cpp\n2. Start the server: ./server -m model.gguf\n3. Specify the port (default is 8080)\n\nAPI key is not required for local usage."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Установите llama.cpp\n2. Запустите сервер: ./server -m model.gguf\n3. Укажите порт (по умолчанию 8080)\n\nAPI ключ не требуется для локальной работы."
          }
        }
      }
    },
    "llm.openai.preset.ollama" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ollama (local)"
