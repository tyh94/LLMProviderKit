    },
    "llm.openai.preset.claude.instructions" : {
      "comment" : "Instructions for using the Claude LLM.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Go to Anthropic Console\n2. Create a new API key\n3. Copy the key and paste it into the field above\n\nNote: The API key is stored only locally on your device and is never sent to our servers."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Перейдите в консоль Anthropic\n2. Создайте новый API ключ\n3. Скопируйте ключ и вставьте его в поле выше\n\nВнимание: API ключ хранится только локально на вашем устройстве и никогда не передаётся на наши сервера."
          }
        }
      }
    },
    "llm.openai.preset.extra.note" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can create multiple spaces for different environments (dev, test, prod)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы можете создать несколько пространств для разных сред (dev, test, prod)"
          }
        }
      }
    },
    "llm.openai.preset.get.key" : {
      "comment" : "A button that opens a website.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get API key →"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Получить API ключ →"
          }
        }
      }
    },
    "llm.openai.preset.gigachat.instructions" : {
      "comment" : "Instructions for using the \"GigaChat\" LLM preset.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Go to Sber developers portal\n2. Create a project and get an API key\n3. Copy the key and paste it into the field above\n\nNote: GigaChat requires authentication with a bearer token. The API key is stored only locally on your device and is never sent to our servers."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Перейдите на портал разработчиков Сбера\n2. Создайте проект и получите API ключ\n3. Скопируйте ключ и вставьте его в поле выше\n\nВнимание: GigaChat требует авторизации с помощью bearer токена. API ключ хранится только локально на вашем устройстве и никогда не передаётся на наши сервера."
          }
        }
      }
    },
    "llm.openai.preset.groq" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Groq (cloud)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Groq (облако)"
          }
        }
      }
    },
    "llm.openai.preset.groq.instructions" : {
      "comment" : "Instructions for using the \"llm.openai.preset.groq\" preset.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Sign up at Groq\n2. Go to developer console\n3. Create an API key\n\nGroq provides free requests for developers."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Зарегистрируйтесь на Groq\n2. Перейдите в консоль разработчика\n3. Создайте API ключ\n\nGroq предоставляет бесплатные запросы для разработчиков."
          }
        }
      }
    },
    "llm.openai.preset.llamacpp" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
